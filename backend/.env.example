# ============================================
# AI Super Hotspot Analysis Assistant
# Production Environment Variables
# ============================================

# Database Configuration
# ============================================
DB_USER=admin
DB_PASSWORD=your_secure_postgres_password
# DATABASE_URL will be constructed automatically from above

# Redis Configuration
# ============================================
REDIS_PASSWORD=your_secure_redis_password

# LLM API Configuration
# ============================================
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat
# Set to True for development, False for production
LLM_MOCK_MODE=False

# Application Security
# ============================================
SECRET_KEY=your-secret-key-change-in-production-with-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days in minutes

# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Data Collection Configuration
# ============================================
UPDATE_SCHEDULE=0 2 * * *  # Daily at 2 AM (cron format)
MAX_HOTSPOTS_PER_UPDATE=100
USE_MOCK_COLLECTOR=False  # Set to True for development with mock data

# Frontend Configuration
# ============================================
VITE_API_BASE_URL=http://localhost:8001/api/v1

# Celery Configuration (optional overrides)
# ============================================
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# Application Settings
# ============================================
APP_NAME=AI超级热点解析助手
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ============================================
# Deployment Notes:
# 1. Copy this file to .env in the project root
# 2. Fill in all values marked with 'your_*'
# 3. For production, ensure:
#    - DEBUG=False
#    - LLM_MOCK_MODE=False
#    - USE_MOCK_COLLECTOR=False
#    - SECRET_KEY is strong and unique
#    - Passwords are strong and not shared
# ============================================