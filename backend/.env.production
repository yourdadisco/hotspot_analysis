# ============================================
# 生产环境部署 - 必填环境变量
# 部署时在 Zeabur/Render 等平台设置即可
# ============================================

# ----- 必填 -----

# 前端地址（用于 CORS），多个用逗号分隔
# 例如：https://frontend.zeabur.app
CORS_ORIGINS=https://frontend.zeabur.app

# LLM API 密钥（DeepSeek 或其他 OpenAI 兼容 API）
LLM_API_KEY=sk-your-key-here

# ----- 数据库（二选一）-----

# 方案A：PostgreSQL（生产推荐），Zeabur 创建 Database 后会自动生成
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db

# 方案B：SQLite（简单但数据不持久，Zeabur 重启会丢失）
# DATABASE_URL=sqlite+aiosqlite:///./hotspot_analysis.db?check_same_thread=false

# ----- 可选 -----

# 是否调试模式（生产环境必须 false）
DEBUG=false

# LLM 配置（默认 deepseek-chat，一般不用改）
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 服务器端口（Zeabur 会自动设置 PORT，不用填）
# PORT=8001

# Redis（不填则无缓存，功能不受影响）
# REDIS_URL=redis://...

# 安全密钥（生产环境建议改）
# SECRET_KEY=change-me-in-production
